{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/RULES.md",
    "AGENTS.md"
  ],
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest", "--browser", "chromium"],
      "enabled": true
    }
  },
  "autoupdate": "notify",
  "formatter": true,
  "lsp": true,
  "share": "manual",
  "snapshot": true
}
